-- MySQL setup script for the search engine database.
-- Adjusted for better performance and best practices.

--------------------------------------------------------------------------------
-- Database Tables setup

-- InformationSeeds table stores the seed information for the crawler
CREATE TABLE IF NOT EXISTS InformationSeed (
    information_seed_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    category_id BIGINT DEFAULT 0 NOT NULL,      -- The category of the information seed.
    usr_id BIGINT DEFAULT 0 NOT NULL,           -- The user that created the information seed
    information_seed VARCHAR(256) NOT NULL,     -- The size of an information seed is limited to 256
                                                -- characters due to the fact that it's used to dork
                                                -- search engines for sources that may be related to
                                                -- the information seed.
    status VARCHAR(50) DEFAULT 'new' NOT NULL,  -- Lifecycle status for seed processing.
    priority VARCHAR(64) DEFAULT '' NOT NULL,   -- Processing priority for the seed.
    engine VARCHAR(256) DEFAULT '' NOT NULL,    -- Engine processing the seed.
    last_processed_at TIMESTAMP NULL,           -- The last time the seed was processed.
    last_error TEXT,                            -- Last processing error for the seed.
    last_error_at TIMESTAMP NULL,               -- The date/time of the last processing error.
    disabled BOOLEAN DEFAULT FALSE,             -- If automatic seed processing is disabled.
    attempts INT DEFAULT 0 NOT NULL,            -- Number of processing attempts.
    config JSON                                 -- Stores JSON document with all details about
                                                -- the information seed configuration for the crawler
);

-- Add lifecycle columns to existing InformationSeed tables without dropping data.
DELIMITER //
CREATE PROCEDURE add_informationseed_column_if_missing(IN p_column_name VARCHAR(64), IN p_column_ddl TEXT)
BEGIN
    IF NOT EXISTS (
        SELECT 1
        FROM INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = DATABASE()
          AND TABLE_NAME = 'InformationSeed'
          AND COLUMN_NAME = p_column_name
    ) THEN
        SET @add_informationseed_column_sql = CONCAT('ALTER TABLE InformationSeed ADD COLUMN ', p_column_ddl);
        PREPARE add_informationseed_column_stmt FROM @add_informationseed_column_sql;
        EXECUTE add_informationseed_column_stmt;
        DEALLOCATE PREPARE add_informationseed_column_stmt;
    END IF;
END//
DELIMITER ;

CALL add_informationseed_column_if_missing('status', 'status VARCHAR(50) DEFAULT \'new\' NOT NULL');
CALL add_informationseed_column_if_missing('priority', 'priority VARCHAR(64) DEFAULT \'\' NOT NULL');
CALL add_informationseed_column_if_missing('engine', 'engine VARCHAR(256) DEFAULT \'\' NOT NULL');
CALL add_informationseed_column_if_missing('last_processed_at', 'last_processed_at TIMESTAMP NULL');
CALL add_informationseed_column_if_missing('last_error', 'last_error TEXT');
CALL add_informationseed_column_if_missing('last_error_at', 'last_error_at TIMESTAMP NULL');
CALL add_informationseed_column_if_missing('disabled', 'disabled BOOLEAN DEFAULT FALSE');
CALL add_informationseed_column_if_missing('attempts', 'attempts INT DEFAULT 0 NOT NULL');

DROP PROCEDURE add_informationseed_column_if_missing;

-- InformationSeedCandidate stores durable audit evidence for every accepted or
-- rejected candidate decision. Rejected rows are intentionally persisted here
-- instead of Sources so rejected candidates never enter the crawl frontier.
CREATE TABLE IF NOT EXISTS InformationSeedCandidate (
    information_seed_candidate_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    information_seed_id BIGINT NOT NULL,
    normalized_url VARCHAR(2048) NOT NULL,
    host VARCHAR(255),
    provider VARCHAR(255) DEFAULT '' NOT NULL,
    query VARCHAR(1024) DEFAULT '' NOT NULL,
    rank INT DEFAULT 0 NOT NULL,
    score DOUBLE DEFAULT 0 NOT NULL,
    decision_status VARCHAR(32) NOT NULL,
    rejection_reason TEXT,
    metadata JSON,
    run_attempt INT DEFAULT 0 NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    CONSTRAINT chk_informationseedcandidate_decision CHECK (decision_status IN ('accepted', 'rejected')),
    UNIQUE KEY uq_informationseedcandidate_decision (information_seed_id, normalized_url(768), provider, query(191), rank, run_attempt),
    KEY idx_informationseedcandidate_seed (information_seed_id, run_attempt, last_updated_at),
    KEY idx_informationseedcandidate_decision (decision_status),
    KEY idx_informationseedcandidate_seed_decision (information_seed_id, decision_status, run_attempt),
    KEY idx_informationseedcandidate_host (host),
    KEY idx_informationseedcandidate_provider (provider),
    KEY idx_informationseedcandidate_normalized_url (normalized_url(768)),
    FOREIGN KEY(information_seed_id) REFERENCES InformationSeed(information_seed_id) ON DELETE CASCADE
);

-- Sources table stores the URLs or the information's seed to be crawled
CREATE TABLE IF NOT EXISTS Sources (
    source_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    source_uid VARCHAR(64) NOT NULL,             -- SHA-256 identifier derived from source name and URL.
    name VARCHAR(255),                          -- The name of the source.
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    usr_id BIGINT DEFAULT 0 NOT NULL,           -- The user that created the source.
    category_id BIGINT DEFAULT 0 NOT NULL,      -- The category of the source.
    url TEXT NOT NULL UNIQUE,                   -- The Source URL.
    priority VARCHAR(64) DEFAULT '' NOT NULL,   -- The priority of the source.
    status VARCHAR(50) DEFAULT 'new' NOT NULL,  -- All new sources are set to 'new' by default.
    engine VARCHAR(256) DEFAULT '' NOT NULL,    -- The engine crawling the source.
    last_crawled_at TIMESTAMP,                  -- The last time the source was crawled.
    last_error TEXT,                            -- Last error message that occurred during crawling.
    last_error_at TIMESTAMP,                    -- The date/time of the last error occurred.
    restricted INT DEFAULT 2 NOT NULL,          -- 0 = fully restricted (just this URL)
                                                -- 1 = l3 domain restricted (everything within this
                                                --     URL l3 domain)
                                                -- 2 = l2 domain restricted
                                                -- 3 = l1 domain restricted
                                                -- 4 = no restrictions
    disabled BOOLEAN DEFAULT FALSE,             -- If the automatic re-crawling/re-scanning of the
                                                -- source is disabled.
    flags INT DEFAULT 0 NOT NULL,               -- Bitwise flags for the source (used for various
                                                -- purposes, included but not limited to the Rules).
    config JSON                                 -- Stores JSON document with all details about
                                                -- the source configuration for the crawler.
);
--------------------------------------------------------------------------------
-- Durable email ingestion checkpoints and bounded message reconciliation state.
CREATE TABLE IF NOT EXISTS EmailMailboxState (
    source_id BIGINT NOT NULL,
    provider VARCHAR(64) NOT NULL,
    account_key VARCHAR(191) NOT NULL,
    mailbox_key VARCHAR(191) NOT NULL,
    cursor_token TEXT NOT NULL,
    cursor_history_id VARCHAR(20) NOT NULL DEFAULT '0',
    cursor_uid BIGINT UNSIGNED NOT NULL DEFAULT 0 CHECK (cursor_uid <= 4294967295),
    cursor_uid_validity BIGINT UNSIGNED NOT NULL DEFAULT 0 CHECK (cursor_uid_validity <= 4294967295),
    checkpoint_schema_version INT UNSIGNED NOT NULL DEFAULT 1 CHECK (checkpoint_schema_version > 0),
    config_fingerprint VARCHAR(128) NOT NULL DEFAULT '',
    message_status VARCHAR(32),
    content_hash VARCHAR(255) NOT NULL DEFAULT '',
    error_count BIGINT UNSIGNED NOT NULL DEFAULT 0,
    last_error VARCHAR(2048) NOT NULL DEFAULT '',
    watch_subscription_id VARCHAR(191) NOT NULL DEFAULT '',
    watch_resource_path VARCHAR(2048) NOT NULL DEFAULT '',
    watch_renewal_status VARCHAR(16) NOT NULL DEFAULT '',
    watch_last_renewed_at TIMESTAMP NULL,
    watch_expires_at TIMESTAMP NULL,
    watch_last_attempt_at TIMESTAMP NULL,
    watch_renewal_failure_count BIGINT UNSIGNED NOT NULL DEFAULT 0,
    watch_renewal_last_error VARCHAR(2048) NOT NULL DEFAULT '',
    version BIGINT UNSIGNED NOT NULL DEFAULT 0,
    lease_owner VARCHAR(191),
    lease_expires_at TIMESTAMP NULL,
    fencing_token BIGINT UNSIGNED NOT NULL DEFAULT 0,
    last_reconciled_at TIMESTAMP NULL,
    listener_healthy_at TIMESTAMP NULL,
    reset_reason VARCHAR(255),
    active BOOLEAN NOT NULL DEFAULT TRUE,
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    last_updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    PRIMARY KEY (source_id, provider, account_key, mailbox_key),
    CONSTRAINT fk_emailmailboxstate_source FOREIGN KEY (source_id) REFERENCES Sources(source_id) ON DELETE CASCADE,
    CONSTRAINT chk_emailmailboxstate_status CHECK (message_status IS NULL OR message_status IN ('discovered', 'fetched', 'parsed', 'normalized', 'attachments_processed', 'links_enqueued', 'completed', 'retryable_failure', 'permanent_failure')),
    CONSTRAINT chk_emailmailboxstate_renewal_status CHECK (watch_renewal_status IN ('', 'healthy', 'due', 'expired', 'failed')),
    CONSTRAINT chk_emailmailboxstate_lease CHECK ((lease_owner IS NULL AND lease_expires_at IS NULL) OR (lease_owner IS NOT NULL AND lease_expires_at IS NOT NULL)),
    KEY idx_emailmailboxstate_lease (lease_expires_at, lease_owner),
    KEY idx_emailmailboxstate_active (source_id, active),
    KEY idx_emailmailboxstate_watch_expiration (watch_expires_at)
);

CREATE TABLE IF NOT EXISTS EmailMessageState (
    source_id BIGINT NOT NULL,
    provider VARCHAR(64) NOT NULL,
    account_key VARCHAR(191) NOT NULL,
    mailbox_key VARCHAR(191) NOT NULL,
    provider_message_key VARCHAR(191) NOT NULL,
    document_id VARCHAR(191) NOT NULL,
    provider_version VARCHAR(255) NOT NULL DEFAULT '',
    content_hash VARCHAR(255) NOT NULL DEFAULT '',
    disposition VARCHAR(16) NOT NULL,
    failure_count BIGINT UNSIGNED NOT NULL DEFAULT 0,
    last_error VARCHAR(2048) NOT NULL DEFAULT '',
    last_observed_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP NULL,
    quarantined_at TIMESTAMP NULL,
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    last_updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    PRIMARY KEY (source_id, provider, account_key, mailbox_key, provider_message_key),
    UNIQUE KEY uq_emailmessagestate_document_id (document_id),
    CONSTRAINT fk_emailmessagestate_mailbox FOREIGN KEY (source_id, provider, account_key, mailbox_key)
        REFERENCES EmailMailboxState(source_id, provider, account_key, mailbox_key) ON DELETE CASCADE,
    CONSTRAINT chk_emailmessagestate_disposition CHECK (disposition IN ('indexed', 'deleted', 'skipped', 'quarantined')),
    CONSTRAINT chk_emailmessagestate_deleted CHECK (disposition <> 'deleted' OR deleted_at IS NOT NULL),
    CONSTRAINT chk_emailmessagestate_quarantined CHECK (disposition <> 'quarantined' OR quarantined_at IS NOT NULL),
    KEY idx_emailmessagestate_observed (source_id, last_observed_at),
    KEY idx_emailmessagestate_disposition (source_id, disposition, last_observed_at)
);


-- Add source discovery columns to existing Sources tables without dropping data.
DELIMITER //
CREATE PROCEDURE add_source_column_if_missing(IN p_column_name VARCHAR(64), IN p_column_ddl TEXT)
BEGIN
    IF NOT EXISTS (
        SELECT 1
        FROM INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = DATABASE()
          AND TABLE_NAME = 'Sources'
          AND COLUMN_NAME = p_column_name
    ) THEN
        SET @add_source_column_sql = CONCAT('ALTER TABLE Sources ADD COLUMN ', p_column_ddl);
        PREPARE add_source_column_stmt FROM @add_source_column_sql;
        EXECUTE add_source_column_stmt;
        DEALLOCATE PREPARE add_source_column_stmt;
    END IF;
END//
DELIMITER ;

CALL add_source_column_if_missing('name', 'name VARCHAR(255)');
CALL add_source_column_if_missing('priority', 'priority VARCHAR(64) DEFAULT '''' NOT NULL');

DROP PROCEDURE add_source_column_if_missing;

-- Owners table stores the information about the owners of the sources
CREATE TABLE IF NOT EXISTS Owners (
    owner_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    usr_id BIGINT NOT NULL,                     -- The user that created the owner
    details_hash VARCHAR(64) UNIQUE NOT NULL,   -- SHA256 hash of the details for fast comparison
                                                -- and uniqueness.
    details JSON NOT NULL                       -- Stores JSON document with all details about
                                                -- the owner.
);

-- SearchIndex table stores the indexed information from the sources
CREATE TABLE IF NOT EXISTS SearchIndex (
    index_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    page_url TEXT NOT NULL UNIQUE,              -- Using TEXT for long URLs
    title VARCHAR(255),                         -- Page title might be NULL
    summary TEXT NOT NULL,                      -- Assuming summary is always required
    detected_type VARCHAR(8),                   -- (content type) denormalized for fast searches
    detected_lang VARCHAR(8)                    -- (URI language) denormalized for fast searches
);

-- Category table stores the categories (and subcategories) for the sources
CREATE TABLE IF NOT EXISTS Category (
    category_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    name VARCHAR(255) UNIQUE NOT NULL,
    description TEXT,
    parent_id BIGINT,
    FOREIGN KEY(parent_id) REFERENCES Category(category_id) ON DELETE SET NULL
);

-- NetInfo table stores the network information retrieved from the sources
CREATE TABLE IF NOT EXISTS NetInfo (
    netinfo_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    details_hash VARCHAR(64) UNIQUE NOT NULL,   -- SHA256 hash of the details for fast comparison
                                                -- and uniqueness.
    details JSON NOT NULL
);

-- HTTPInfo table stores the HTTP header information retrieved from the sources
CREATE TABLE IF NOT EXISTS HTTPInfo (
    httpinfo_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    details_hash VARCHAR(64) UNIQUE NOT NULL,   -- SHA256 hash of the details for fast comparison
                                                -- and uniqueness
    details JSON NOT NULL
);

-- Screenshots table stores the screenshots details of the indexed pages
CREATE TABLE IF NOT EXISTS Screenshots (
    screenshot_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    index_id BIGINT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    type VARCHAR(10) NOT NULL DEFAULT 'desktop',
    screenshot_link TEXT NOT NULL,
    height INT NOT NULL DEFAULT 0,
    width INT NOT NULL DEFAULT 0,
    byte_size INT NOT NULL DEFAULT 0,
    thumbnail_height INT NOT NULL DEFAULT 0,
    thumbnail_width INT NOT NULL DEFAULT 0,
    thumbnail_link TEXT NOT NULL DEFAULT '',
    format VARCHAR(10) NOT NULL DEFAULT 'png',
    FOREIGN KEY (index_id) REFERENCES SearchIndex(index_id) ON DELETE CASCADE
);

-- WebObjects table stores all types of web objects found in the indexed pages
-- This includes scripts, styles, images, iframes, HTML etc.
CREATE TABLE IF NOT EXISTS WebObjects (
    object_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    object_link TEXT NOT NULL DEFAULT 'db',     -- The link to where the object is stored if not
                                                -- in the DB.
    object_type VARCHAR(255) NOT NULL DEFAULT 'text/html', -- The type of the object, for fast searches
    object_hash VARCHAR(64) UNIQUE NOT NULL,    -- SHA256 hash of the object for fast comparison
                                                -- and uniqueness.
    object_content TEXT,                        -- The actual content of the object, nullable if
                                                -- stored externally.
    object_html TEXT,                           -- The HTML content of the object, nullable if
                                                -- stored externally.
    details JSON NOT NULL                       -- Stores JSON document with all details about
                                                -- the object.
);

-- MetaTags table stores the meta tags from the SearchIndex
CREATE TABLE IF NOT EXISTS MetaTags (
    metatag_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    content TEXT NOT NULL,
    UNIQUE(name, content)                       -- Ensure that each name-content pair is unique
);

-- Keywords table stores all the found keywords during an indexing
CREATE TABLE IF NOT EXISTS Keywords (
    keyword_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    keyword VARCHAR(256) NOT NULL UNIQUE
);

-- Events table stores the events generated by the system
CREATE TABLE IF NOT EXISTS Events (
    event_sha256 CHAR(64) PRIMARY KEY,
    source_id BIGINT,
    event_type VARCHAR(255) NOT NULL,
    event_severity VARCHAR(50) NOT NULL,
    event_timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    details JSON NOT NULL,
    FOREIGN KEY(source_id) REFERENCES Sources(source_id) ON DELETE CASCADE
);

----------------------------------------
-- Relationship tables

-- SourceInformationSeedIndex table stores the relationship between sources and their information seeds
CREATE TABLE IF NOT EXISTS SourceInformationSeedIndex (
    source_information_seed_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    source_id BIGINT NOT NULL,
    information_seed_id BIGINT NOT NULL,
    discovery_provider VARCHAR(255),          -- Provider that discovered this source for this seed.
    discovery_query TEXT,                     -- Query/dork/prompt used for this discovery.
    discovery_rank INT,                       -- Rank returned by the discovery provider.
    candidate_score DOUBLE,                   -- Score assigned before promotion to Sources.
    candidate_reason TEXT,                    -- Human/model-readable reason for the candidate.
    discovery_metadata JSON,                  -- Additional per-discovery metadata for this source/seed pair.
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE (source_id, information_seed_id),
    FOREIGN KEY(source_id) REFERENCES Sources(source_id) ON DELETE CASCADE,
    FOREIGN KEY(information_seed_id) REFERENCES InformationSeed(information_seed_id) ON DELETE CASCADE
);

-- Add per-discovery provenance columns to existing SourceInformationSeedIndex tables without dropping data.
DELIMITER //
CREATE PROCEDURE add_sourceinformationseed_column_if_missing(IN p_column_name VARCHAR(64), IN p_column_ddl TEXT)
BEGIN
    IF NOT EXISTS (
        SELECT 1
        FROM INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = DATABASE()
          AND TABLE_NAME = 'SourceInformationSeedIndex'
          AND COLUMN_NAME = p_column_name
    ) THEN
        SET @add_sourceinformationseed_column_sql = CONCAT('ALTER TABLE SourceInformationSeedIndex ADD COLUMN ', p_column_ddl);
        PREPARE add_sourceinformationseed_column_stmt FROM @add_sourceinformationseed_column_sql;
        EXECUTE add_sourceinformationseed_column_stmt;
        DEALLOCATE PREPARE add_sourceinformationseed_column_stmt;
    END IF;
END//
DELIMITER ;

CALL add_sourceinformationseed_column_if_missing('discovery_provider', 'discovery_provider VARCHAR(255)');
CALL add_sourceinformationseed_column_if_missing('discovery_query', 'discovery_query TEXT');
CALL add_sourceinformationseed_column_if_missing('discovery_rank', 'discovery_rank INT');
CALL add_sourceinformationseed_column_if_missing('candidate_score', 'candidate_score DOUBLE');
CALL add_sourceinformationseed_column_if_missing('candidate_reason', 'candidate_reason TEXT');
CALL add_sourceinformationseed_column_if_missing('discovery_metadata', 'discovery_metadata JSON');

DROP PROCEDURE add_sourceinformationseed_column_if_missing;

-- SourceOwnerIndex table stores the relationship between sources and their owners
CREATE TABLE IF NOT EXISTS SourceOwnerIndex (
    source_owner_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    source_id BIGINT NOT NULL,
    owner_id BIGINT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE(source_id, owner_id),
    FOREIGN KEY(source_id) REFERENCES Sources(source_id) ON DELETE CASCADE,
    FOREIGN KEY(owner_id) REFERENCES Owners(owner_id) ON DELETE CASCADE
);

-- SourceSearchIndex table stores the relationship between sources and the indexed pages
CREATE TABLE IF NOT EXISTS SourceSearchIndex (
    ss_index_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    source_id BIGINT NOT NULL,
    index_id BIGINT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE(source_id, index_id),
    FOREIGN KEY(source_id) REFERENCES Sources(source_id) ON DELETE CASCADE,
    FOREIGN KEY(index_id) REFERENCES SearchIndex(index_id) ON DELETE CASCADE
);

-- SourceCategoryIndex table stores the relationship between sources and their categories
CREATE TABLE IF NOT EXISTS SourceCategoryIndex (
    source_category_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    source_id BIGINT NOT NULL,
    category_id BIGINT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE(source_id, category_id),
    FOREIGN KEY(source_id) REFERENCES Sources(source_id) ON DELETE CASCADE,
    FOREIGN KEY(category_id) REFERENCES Category(category_id) ON DELETE CASCADE
);

-- WebObjectsIndex table stores the relationship between indexed pages and the objects found in them
CREATE TABLE IF NOT EXISTS WebObjectsIndex (
    page_object_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    index_id BIGINT NOT NULL,
    object_id BIGINT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE(index_id, object_id),
    FOREIGN KEY(index_id) REFERENCES SearchIndex(index_id) ON DELETE CASCADE,
    FOREIGN KEY(object_id) REFERENCES WebObjects(object_id) ON DELETE CASCADE
);

-- Relationship table between SearchIndex and MetaTags
CREATE TABLE IF NOT EXISTS MetaTagsIndex (
    sim_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    index_id BIGINT NOT NULL,
    metatag_id BIGINT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    UNIQUE(index_id, metatag_id),
    FOREIGN KEY(index_id) REFERENCES SearchIndex(index_id) ON DELETE CASCADE,
    FOREIGN KEY(metatag_id) REFERENCES MetaTags(metatag_id) ON DELETE CASCADE
);

-- KeywordIndex table stores the relationship between keywords and the indexed pages
CREATE TABLE IF NOT EXISTS KeywordIndex (
    keyword_index_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    keyword_id BIGINT,
    index_id BIGINT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    occurrences INT,
    UNIQUE(keyword_id, index_id),
    FOREIGN KEY(index_id) REFERENCES SearchIndex(index_id) ON DELETE CASCADE,
    FOREIGN KEY(keyword_id) REFERENCES Keywords(keyword_id) ON DELETE CASCADE
);

-- NetInfoIndex table stores the relationship between network information and the indexed pages
CREATE TABLE IF NOT EXISTS NetInfoIndex (
    netinfo_index_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    netinfo_id BIGINT,
    index_id BIGINT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE(netinfo_id, index_id),
    FOREIGN KEY(index_id) REFERENCES SearchIndex(index_id) ON DELETE CASCADE,
    FOREIGN KEY(netinfo_id) REFERENCES NetInfo(netinfo_id) ON DELETE CASCADE
);

-- HTTPInfoIndex table stores the relationship between HTTP information and the indexed pages
CREATE TABLE IF NOT EXISTS HTTPInfoIndex (
    httpinfo_index_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    httpinfo_id BIGINT,
    index_id BIGINT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    last_updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    UNIQUE(httpinfo_id, index_id),
    FOREIGN KEY(index_id) REFERENCES SearchIndex(index_id) ON DELETE CASCADE,
    FOREIGN KEY(httpinfo_id) REFERENCES HTTPInfo(httpinfo_id) ON DELETE CASCADE
);

--------------------------------------------------------------------------------
-- Indexes and triggers setup

-- Guarded InformationSeed lifecycle indexes
DELIMITER //
CREATE PROCEDURE add_informationseed_index_if_missing(IN p_index_name VARCHAR(64), IN p_index_ddl TEXT)
BEGIN
    IF NOT EXISTS (
        SELECT 1
        FROM INFORMATION_SCHEMA.STATISTICS
        WHERE TABLE_SCHEMA = DATABASE()
          AND TABLE_NAME = 'InformationSeed'
          AND INDEX_NAME = p_index_name
    ) THEN
        SET @add_informationseed_index_sql = p_index_ddl;
        PREPARE add_informationseed_index_stmt FROM @add_informationseed_index_sql;
        EXECUTE add_informationseed_index_stmt;
        DEALLOCATE PREPARE add_informationseed_index_stmt;
    END IF;
END//
DELIMITER ;

CALL add_informationseed_index_if_missing('idx_informationseed_status', 'CREATE INDEX idx_informationseed_status ON InformationSeed(status)');
CALL add_informationseed_index_if_missing('idx_informationseed_priority', 'CREATE INDEX idx_informationseed_priority ON InformationSeed(priority)');
CALL add_informationseed_index_if_missing('idx_informationseed_disabled', 'CREATE INDEX idx_informationseed_disabled ON InformationSeed(disabled)');
CALL add_informationseed_index_if_missing('idx_informationseed_last_processed_at', 'CREATE INDEX idx_informationseed_last_processed_at ON InformationSeed(last_processed_at)');
CALL add_informationseed_index_if_missing('idx_informationseed_last_error_at', 'CREATE INDEX idx_informationseed_last_error_at ON InformationSeed(last_error_at)');
CALL add_informationseed_index_if_missing('idx_informationseed_processing_stale', 'CREATE INDEX idx_informationseed_processing_stale ON InformationSeed(status, disabled, last_processed_at)');
CALL add_informationseed_index_if_missing('idx_informationseed_claim_queue', 'CREATE INDEX idx_informationseed_claim_queue ON InformationSeed(disabled, status, priority, created_at, information_seed_id)');
CALL add_informationseed_index_if_missing('idx_informationseed_engine_status', 'CREATE INDEX idx_informationseed_engine_status ON InformationSeed(engine, status, last_processed_at)');

DROP PROCEDURE add_informationseed_index_if_missing;

-- Guarded InformationSeedCandidate lookup indexes for upgraded databases where
-- the table may already exist without the current read-path indexes.
DELIMITER //
CREATE PROCEDURE add_informationseedcandidate_index_if_missing(IN p_index_name VARCHAR(64), IN p_index_ddl TEXT)
BEGIN
    IF NOT EXISTS (
        SELECT 1
        FROM INFORMATION_SCHEMA.STATISTICS
        WHERE TABLE_SCHEMA = DATABASE()
          AND TABLE_NAME = 'InformationSeedCandidate'
          AND INDEX_NAME = p_index_name
    ) THEN
        SET @add_informationseedcandidate_index_sql = p_index_ddl;
        PREPARE add_informationseedcandidate_index_stmt FROM @add_informationseedcandidate_index_sql;
        EXECUTE add_informationseedcandidate_index_stmt;
        DEALLOCATE PREPARE add_informationseedcandidate_index_stmt;
    END IF;
END//
DELIMITER ;

CALL add_informationseedcandidate_index_if_missing('idx_informationseedcandidate_seed', 'CREATE INDEX idx_informationseedcandidate_seed ON InformationSeedCandidate(information_seed_id, run_attempt, last_updated_at)');
CALL add_informationseedcandidate_index_if_missing('idx_informationseedcandidate_decision', 'CREATE INDEX idx_informationseedcandidate_decision ON InformationSeedCandidate(decision_status)');
CALL add_informationseedcandidate_index_if_missing('idx_informationseedcandidate_seed_decision', 'CREATE INDEX idx_informationseedcandidate_seed_decision ON InformationSeedCandidate(information_seed_id, decision_status, run_attempt)');
CALL add_informationseedcandidate_index_if_missing('idx_informationseedcandidate_host', 'CREATE INDEX idx_informationseedcandidate_host ON InformationSeedCandidate(host)');
CALL add_informationseedcandidate_index_if_missing('idx_informationseedcandidate_provider', 'CREATE INDEX idx_informationseedcandidate_provider ON InformationSeedCandidate(provider)');
CALL add_informationseedcandidate_index_if_missing('idx_informationseedcandidate_normalized_url', 'CREATE INDEX idx_informationseedcandidate_normalized_url ON InformationSeedCandidate(normalized_url(768))');

DROP PROCEDURE add_informationseedcandidate_index_if_missing;

-- Guarded SourceInformationSeedIndex inspection indexes.
DELIMITER //
CREATE PROCEDURE add_sourceinformationseed_index_if_missing(IN p_index_name VARCHAR(64), IN p_index_ddl TEXT)
BEGIN
    IF NOT EXISTS (
        SELECT 1
        FROM INFORMATION_SCHEMA.STATISTICS
        WHERE TABLE_SCHEMA = DATABASE()
          AND TABLE_NAME = 'SourceInformationSeedIndex'
          AND INDEX_NAME = p_index_name
    ) THEN
        SET @add_sourceinformationseed_index_sql = p_index_ddl;
        PREPARE add_sourceinformationseed_index_stmt FROM @add_sourceinformationseed_index_sql;
        EXECUTE add_sourceinformationseed_index_stmt;
        DEALLOCATE PREPARE add_sourceinformationseed_index_stmt;
    END IF;
END//
DELIMITER ;

CALL add_sourceinformationseed_index_if_missing('idx_sourceinformationseedindex_information_seed_id', 'CREATE INDEX idx_sourceinformationseedindex_information_seed_id ON SourceInformationSeedIndex(information_seed_id)');
CALL add_sourceinformationseed_index_if_missing('idx_sourceinformationseedindex_source_id', 'CREATE INDEX idx_sourceinformationseedindex_source_id ON SourceInformationSeedIndex(source_id)');
CALL add_sourceinformationseed_index_if_missing('idx_sourceinformationseedindex_seed_source', 'CREATE INDEX idx_sourceinformationseedindex_seed_source ON SourceInformationSeedIndex(information_seed_id, source_id)');
CALL add_sourceinformationseed_index_if_missing('idx_sourceinformationseedindex_provider_rank', 'CREATE INDEX idx_sourceinformationseedindex_provider_rank ON SourceInformationSeedIndex(information_seed_id, discovery_provider, discovery_rank)');

DROP PROCEDURE add_sourceinformationseed_index_if_missing;


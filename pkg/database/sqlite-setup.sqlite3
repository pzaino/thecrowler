-- PostgreSQL cleanup_artifact_data() trigger equivalents.
CREATE TRIGGER IF NOT EXISTS trg_cleanup_webobject
AFTER DELETE ON WebObjects
FOR EACH ROW
BEGIN
    DELETE FROM ObjectAttributes WHERE object_type = 'webobject' AND object_id = OLD.object_id;
    DELETE FROM EntityMemberships WHERE object_type = 'webobject' AND object_id = OLD.object_id;
    DELETE FROM ObjectCorrelations WHERE (object_type_1 = 'webobject' AND object_id_1 = OLD.object_id) OR (object_type_2 = 'webobject' AND object_id_2 = OLD.object_id);
END;

CREATE TRIGGER IF NOT EXISTS trg_cleanup_netinfo
AFTER DELETE ON NetInfo
FOR EACH ROW
BEGIN
    DELETE FROM ObjectAttributes WHERE object_type = 'netinfo' AND object_id = OLD.netinfo_id;
    DELETE FROM EntityMemberships WHERE object_type = 'netinfo' AND object_id = OLD.netinfo_id;
    DELETE FROM ObjectCorrelations WHERE (object_type_1 = 'netinfo' AND object_id_1 = OLD.netinfo_id) OR (object_type_2 = 'netinfo' AND object_id_2 = OLD.netinfo_id);
END;

CREATE TRIGGER IF NOT EXISTS trg_cleanup_httpinfo
AFTER DELETE ON HTTPInfo
FOR EACH ROW
BEGIN
    DELETE FROM ObjectAttributes WHERE object_type = 'httpinfo' AND object_id = OLD.httpinfo_id;
    DELETE FROM EntityMemberships WHERE object_type = 'httpinfo' AND object_id = OLD.httpinfo_id;
    DELETE FROM ObjectCorrelations WHERE (object_type_1 = 'httpinfo' AND object_id_1 = OLD.httpinfo_id) OR (object_type_2 = 'httpinfo' AND object_id_2 = OLD.httpinfo_id);
END;

CREATE TRIGGER IF NOT EXISTS trg_after_delete_source_searchindex
AFTER DELETE ON SourceSearchIndex
FOR EACH ROW
BEGIN
    DELETE FROM SearchIndex
    WHERE index_id = OLD.index_id
      AND NOT EXISTS (SELECT 1 FROM SourceSearchIndex WHERE index_id = OLD.index_id);
END;

-- Dummy no-op equivalent for PostgreSQL notify_new_event() trigger.
CREATE TRIGGER IF NOT EXISTS trg_notify_new_event
AFTER INSERT ON Events
FOR EACH ROW
BEGIN
    SELECT NEW.event_sha256;
END;

